<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>

    <!-- Fuentes -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">

    <!-- Estilos -->
    <style>
      :root {
        --font-heading: 'Orbitron', sans-serif;
        --color-white: #ffffff;
        --color-dark: #1a1a1a;
        --color-metal-blue: #5fa8d3;
        --color-blue-glow: #90c3e8;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: var(--font-heading);
        background: linear-gradient(to bottom right, var(--color-white), #f5f7fa);
        color: var(--color-metal-blue);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        text-align: center;
      }

      h1 {
        font-size: 4rem;
        text-shadow: 0 0 10px var(--color-blue-glow);
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 3rem;
        }
      }

      @media (max-width: 480px) {
        h1 {
          font-size: 2.2rem;
        }
      }
    </style>

    {{ content_for_header }}
  </head>

  <body>
    <h1>AuraGK</h1>
    {{ content_for_layout }}
    <script src="{{ 'script.js' | asset_url }}"></script>
  </body>
</html>
