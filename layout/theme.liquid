<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }}</title>
    <meta name="description" content="AuraGK: Descubre productos únicos y vive la experiencia digital.">
    <meta name="theme-color" content="#000000">

    <!-- Fuentes -->
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&display=swap" rel="stylesheet">

    <!-- Estilos -->
    <link rel="stylesheet" href="{{ 'styles.css' | asset_url }}">
    {{ content_for_header }}
  </head>
  <body>
    <!-- Fondo de video -->
    <video id="background-video" autoplay muted loop playsinline>
      <source src="{{ 'Video.mp4' | asset_url }}" type="video/mp4">
      <source src="{{ 'Video(1).webm' | asset_url }}" type="video/webm">
      Tu navegador no soporta la etiqueta de video.
    </video>

    {{ content_for_layout }}

    <!-- Scripts -->
    <script src="{{ 'script.js' | asset_url }}"></script>
  </body>
</html>
