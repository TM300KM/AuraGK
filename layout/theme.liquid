<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {% if collection %}
      {{ collection.title }} - {{ shop.name }}
    {% else %}
      {{ shop.name }}
    {% endif %}
  </title>
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'styles.css' | asset_url }}">
</head>
<body>
  <div class="hero-bg-video">
    <video id="heroVideo" autoplay loop muted playsinline preload="auto">
      <source src="https://cdn.shopify.com/videos/c/o/v/0e15a77514754d75bcda3d4a8e3271d7.mp4" type="video/mp4">
      Tu navegador no soporta la etiqueta de video.
    </video>
    <div class="content-overlay">
      <header>
        <h1>
          {% if collection %}
            {{ collection.title }}
          {% else %}
            {{ shop.name }}
          {% endif %}
        </h1>
      </header>
      <main>
        <div class="product-grid">
          {% if collection and collection.products.size > 0 %}
            {% for product in collection.products %}
              <div class="product-card">
                <a href="{{ product.url }}">
                  <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
                  <h3>{{ product.title }}</h3>
                  <p>{{ product.price | money }}</p>
                </a>
              </div>
            {% endfor %}
          {% else %}
            <p>No products found.</p>
          {% endif %}
        </div>
      </main>
    </div>
  </div>
  <script src="{{ 'script.js' | asset_url }}" defer></script>
</body>
</html>