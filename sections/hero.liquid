/* Elimina estas líneas de .container */
--bg: linear-gradient(
  45deg,
  rgb(0, 0, 0) 25%,
  transparent 25%,
  transparent 75%,
  rgb(0, 0, 0) 75%,
  rgb(0, 0, 0)
  ),
  linear-gradient(
  45deg,
  rgb(0, 0, 0) 25%,
  white 25%,
  white 75%,
  rgb(0, 0, 0) 75%,
  rgb(0, 0, 0)
  );
--bgsize: 60px 60px;
--bgposition: 0 0, 30px 30px;
background-image: var(--bg);
background-size: var(--bgsize);
background-position: var(--bgposition);
