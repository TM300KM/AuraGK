<!-- Removed duplicate/conflicting #storeName styles to avoid CSS conflicts -->
<style>
/* --- HERO STORE NAME EFFECT --- */
#storeName {
  display: none;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  color: #fff;
  font-size: clamp(2rem, 8vw, 6rem);
  font-weight: bold;
  letter-spacing: 0.15em;
  text-shadow:
    0 2px 8px #000,
    0 0 10px #00ffe7,
    0 0 20px #00ffe7,
    2px 2px 0 #ff00c8,
    -2px -2px 0 #00ffe7,
    0 8px 24px #000;
  background: linear-gradient(90deg, #00ffe7 0%, #ff00c8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 12px #00ffe7) drop-shadow(0 0 24px #ff00c8);
  perspective: 400px;
  animation: storeNameFadeIn 1.2s cubic-bezier(0.4,0,0.2,1) forwards;
}

@media (min-resolution: 2dppx), (min-resolution: 192dpi) {
  .hero-bg-video video,
  .hero-bg-video {
    image-rendering: auto;
    filter: none;
  }
}

@media (max-width: 600px) {
  .hero-bg-video video {
    width: 100vw;
    height: 100vh;
  }
}

@keyframes storeNameFadeIn {
  from {
    opacity: 0;
    transform: translate(-50%,-60%) scale(0.95) perspective(400px) rotateX(20deg);
    filter: blur(8px) drop-shadow(0 0 24px #00ffe7);
  }
  to {
    opacity: 1;
    transform: translate(-50%,-50%) scale(1) perspective(400px) rotateX(0deg);
    filter: blur(0) drop-shadow(0 0 24px #00ffe7);
  }
}