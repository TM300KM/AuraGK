.hero-bg-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  object-fit: cover;
  z-index: -1;
}
.hero-bg-video video {
  width: 100vw;
  height: 100vh;
  object-fit: cover;
}

