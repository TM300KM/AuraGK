<section class="hero">
  <div class="overlay"></div>
  <div class="hero-content">
    <h1 class="hero-title" id="hero-title">Bienvenido a AuraGK</h1>
    <p class="hero-subtitle">Donde el estilo y la tecnología se fusionan.</p>
    <a href="/collections/all" class="btn">Explorar Catálogo</a>
  </div>
</section>

<style>
.hero {
  position: relative;
  background: url('{{ 'hero-bg.jpg' | asset_url }}') no-repeat center center;
  background-size: cover;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  color: white;
  perspective: 1000px;
  overflow: hidden;
}

.overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 20px;
}

.hero-title {
  font-size: 3rem;
  margin-bottom: 1rem;
  color: #fff;
  transform-style: preserve-3d;
  transition: transform 0.1s ease-out;
  font-weight: 900;
  text-shadow: 0 0 20px rgba(255, 106, 0, 0.8);
}

.hero-subtitle {
  font-size: 1.5rem;
  margin-bottom: 2rem;
}

.btn {
  background: #ff6a00;
  color: white;
  padding: 12px 24px;
  font-weight: bold;
  border: none;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.3s ease;
}

.btn:hover {
  background: #e55b00;
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const title = document.getElementById("hero-title");

    function rotateTitle(x, y) {
      const rotateX = (y - window.innerHeight / 2) / 20;
      const rotateY = (x - window.innerWidth / 2) / 20;
      title.style.transform = `rotateX(${ -rotateX }deg) rotateY(${ rotateY }deg)`;
    }

    // PC - Mouse
    window.addEventListener("mousemove", e => {
      rotateTitle(e.clientX, e.clientY);
    });

    // Móviles - Toque
    window.addEventListener("touchmove", e => {
      if (e.touches.length > 0) {
        const touch = e.touches[0];
        rotateTitle(touch.clientX, touch.clientY);
      }
    });
  });
</script>
