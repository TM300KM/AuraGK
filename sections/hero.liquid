<section class="hero container">
  <div class="hero-content">
    <h1 class="hero-title" id="hero-title">Bienvenido a AuraGK</h1>
    <p class="hero-subtitle">Donde el estilo y la tecnología se fusionan.</p>
    <a href="/collections/all" class="btn">Explorar Catálogo</a>
  </div>
</section>

<style>
/* Fondo tipo tablero dinámico */
.container {
  width: 100%;
  height: 100vh;
  --bg: linear-gradient(
      45deg,
      rgb(0, 0, 0) 25%,
      transparent 25%,
      transparent 75%,
      rgb(0, 0, 0) 75%,
      rgb(0, 0, 0)
    ),
    linear-gradient(
      45deg,
      rgb(0, 0, 0) 25%,
      white 25%,
      white 75%,
      rgb(0, 0, 0) 75%,
      rgb(0, 0, 0)
    );
  --bgsize: 60px 60px;
  --bgposition: 0 0, 30px 30px;
  background-color: white;
  background-image: var(--bg);
  background-size: var(--bgsize);
  background-position: var(--bgposition);
  position: relative;
  perspective: 1000px;
  transform-style: preserve-3d;
  overflow: hidden;
  box-shadow: inset 0px 0px 500px rgb(15, 15, 15);
}

.container::before {
  content: "";
  width: 100%;
  height: 150%;
  box-shadow: 0px -100px 500px black, inset 0px 100px 500px rgb(15, 15, 15);
  position: absolute;
  top: 55%;
  background-image: var(--bg);
  background-size: var(--bgsize);
  background-position: var(--bgposition);
  transform-origin: top;
  transform: rotateX(80deg);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  color: white;
  padding: 20px;
}

.hero-title {
  font-size: 3rem;
  margin-bottom: 1rem;
  font-weight: 900;
  text-shadow: 0 0 20px rgba(255, 106, 0, 0.8);
  transform-style: preserve-3d;
  transition: transform 0.1s ease-out;
}

.hero-subtitle {
  font-size: 1.5rem;
  margin-bottom: 2rem;
}

.btn {
  background: #ff6a00;
  color: white;
  padding: 12px 24px;
  font-weight: bold;
  border: none;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 0 10px rgba(255, 106, 0, 0.3);
  position: relative;
  z-index: 2;
}

/* Glow effect en hover y click */
.btn:hover,
.btn:focus,
.btn:active {
  box-shadow: 0 0 20px rgba(255, 106, 0, 0.8), 0 0 40px rgba(255, 106, 0, 0.6);
  transform: scale(1.05);
}

/* Compatibilidad con móviles */
@media (hover: none) {
  .btn:active {
    box-shadow: 0 0 20px rgba(255, 106, 0, 0.8), 0 0 40px rgba(255, 106, 0, 0.6);
    transform: scale(1.05);
  }
}
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const title = document.getElementById("hero-title");

    function rotateTitle(x, y) {
      const rotateX = (y - window.innerHeight / 2) / 20;
      const rotateY = (x - window.innerWidth / 2) / 20;
      title.style.transform = `rotateX(${ -rotateX }deg) rotateY(${ rotateY }deg)`;
    }

    window.addEventListener("mousemove", e => {
      rotateTitle(e.clientX, e.clientY);
    });

    window.addEventListener("touchmove", e => {
      if (e.touches.length > 0) {
        const touch = e.touches[0];
        rotateTitle(touch.clientX, touch.clientY);
      }
    });
  });
</script>
